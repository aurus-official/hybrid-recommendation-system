package rules.crop

import com.aurus.server.engine.EngineCategoryOutputDTO;
import com.aurus.server.batch.derive.weather.DerivedWeatherDataModel;
import com.aurus.server.batch.derive.sensor.DerivedSensorDataModel;
import com.aurus.server.shared.PriorityLevel;
import com.aurus.server.shared.SeverityLevel;
import com.aurus.server.shared.CategoryType;

global java.util.List intermediateOutputs;

/* =========================
   CRITICAL – Suspend Operations
   ========================= */
rule "Crop - Suspend Operations (Extreme Stress)"
salience 100
when
    $s : DerivedSensorDataModel()
    $w : DerivedWeatherDataModel()
    eval(
        (0.6f * $s.getPlantStressIndex() + 0.4f * $w.getPlantStressIndex()) >= 0.85f ||
        (0.6f * $s.getHeatStressIndex() + 0.4f * $w.getHeatStressIndex()) >= 0.85f
    )
then
    float psi = 0.6f * $s.getPlantStressIndex() + 0.4f * $w.getPlantStressIndex();
    float hsi = 0.6f * $s.getHeatStressIndex() + 0.4f * $w.getHeatStressIndex();

    EngineCategoryOutputDTO out = new EngineCategoryOutputDTO();
    out.setCategoryType(CategoryType.CROP_OPERATION);
    out.setAction("suspend_field_operations_protect_crop");
    out.setSeverityLevel(SeverityLevel.CRITICAL);
    out.setPriorityLevel(PriorityLevel.P0);

    float confidence = 0.5f * psi + 0.5f * hsi;
    out.setConfidence(Math.min(1f, Math.max(0f, confidence)));

    intermediateOutputs.add(out);
end


/* =========================
   VERY HIGH – Delay Operations
   ========================= */
rule "Crop - Delay Operations (High Stress)"
salience 90
when
    $s : DerivedSensorDataModel()
    $w : DerivedWeatherDataModel()
    eval(
        (0.6f * $s.getPlantStressIndex() + 0.4f * $w.getPlantStressIndex()) >= 0.7f &&
        (0.6f * $s.getPlantStressIndex() + 0.4f * $w.getPlantStressIndex()) < 0.85f
    )
then
    float psi = 0.6f * $s.getPlantStressIndex() + 0.4f * $w.getPlantStressIndex();

    EngineCategoryOutputDTO out = new EngineCategoryOutputDTO();
    out.setCategoryType(CategoryType.CROP_OPERATION);
    out.setAction("delay_non_essential_crop_operations");
    out.setSeverityLevel(SeverityLevel.CRITICAL);
    out.setPriorityLevel(PriorityLevel.P0);

    out.setConfidence(Math.min(1f, psi));
    intermediateOutputs.add(out);
end


/* =========================
   HIGH – Rain-Based Adjustment
   ========================= */
rule "Crop - Rain Adjust Operations"
salience 80
when
    $w : DerivedWeatherDataModel(rainImpactIndex >= 0.7)
then
    EngineCategoryOutputDTO out = new EngineCategoryOutputDTO();

    out.setCategoryType(CategoryType.CROP_OPERATION);
    out.setAction("adjust_operations_due_to_high_rainfall");
    out.setSeverityLevel(SeverityLevel.HIGH);
    out.setPriorityLevel(PriorityLevel.P1);

    float confidence = $w.getRainImpactIndex();

    out.setConfidence(Math.min(1f, Math.max(0f, confidence)));
    intermediateOutputs.add(out);
end


/* =========================
   MODERATE – Controlled Operations
   ========================= */
rule "Crop - Controlled Operations (Moderate Stress)"
salience 70
when
    $s : DerivedSensorDataModel()
    $w : DerivedWeatherDataModel()
    eval(
        (0.6f * $s.getPlantStressIndex() + 0.4f * $w.getPlantStressIndex()) >= 0.5f &&
        (0.6f * $s.getPlantStressIndex() + 0.4f * $w.getPlantStressIndex()) < 0.7f
    )
then
    float psi = 0.6f * $s.getPlantStressIndex() + 0.4f * $w.getPlantStressIndex();

    EngineCategoryOutputDTO out = new EngineCategoryOutputDTO();
    out.setCategoryType(CategoryType.CROP_OPERATION);
    out.setAction("perform_operations_with_caution_reduce_stress");
    out.setSeverityLevel(SeverityLevel.MODERATE);
    out.setPriorityLevel(PriorityLevel.P2);

    float confidence =
        1f - Math.abs(psi - 0.6f) * 2f;

    out.setConfidence(Math.min(1f, Math.max(0f, confidence)));
    intermediateOutputs.add(out);
end


/* =========================
   LOW – Optimal Operations
   ========================= */
rule "Crop - Optimal Conditions"
salience 60
when
    $s : DerivedSensorDataModel()
    $w : DerivedWeatherDataModel()
    eval(
        (0.6f * $s.getPlantStressIndex() + 0.4f * $w.getPlantStressIndex()) < 0.5f
    )
then
    float psi = 0.6f * $s.getPlantStressIndex() + 0.4f * $w.getPlantStressIndex();

    EngineCategoryOutputDTO out = new EngineCategoryOutputDTO();
    out.setCategoryType(CategoryType.CROP_OPERATION);
    out.setAction("proceed_with_normal_crop_operations");
    out.setSeverityLevel(SeverityLevel.LOW);
    out.setPriorityLevel(PriorityLevel.P3);

    float confidence =
        0.7f * (1 - psi) +
        0.3f * (1 - $w.getRainImpactIndex());

    out.setConfidence(Math.min(1f, Math.max(0f, confidence)));
    intermediateOutputs.add(out);
end
