package rules

import com.aurus.server.engine.EngineCategoryOutputDTO;
import com.aurus.server.batch.derive.weather.DerivedWeatherDataModel;
import com.aurus.server.batch.derive.sensor.DerivedSensorDataModel;
import com.aurus.server.shared.PriorityLevel;
import com.aurus.server.shared.SeverityLevel;
import com.aurus.server.shared.CategoryType;

global java.util.List intermediateOutputs;

rule "Microclimate - Extreme Heat"
salience 98
when
    $s : DerivedSensorDataModel()
    $w : DerivedWeatherDataModel(rainImpactIndex < 0.4)
then
    float combinedHSI =
        0.6f * $s.getHeatStressIndex() +
        0.4f * $w.getHeatStressIndex();

    if (combinedHSI <= 0.85f) return;

    EngineCategoryOutputDTO out = new EngineCategoryOutputDTO();

    out.setCategoryType(CategoryType.MICROCLIMATE);
    out.setAction("emergency_cooling");
    out.setSeverityLevel(SeverityLevel.CRITICAL);
    out.setPriorityLevel(PriorityLevel.P1);

    float confidence =
        0.7f * combinedHSI +
        0.3f * (1 - $w.getRainImpactIndex());

    out.setConfidence(Math.max(0f, Math.min(1f, confidence)));

    intermediateOutputs.add(out);
end

rule "Microclimate - Heat Mitigation"
salience 90
when
    $s : DerivedSensorDataModel()
    $w : DerivedWeatherDataModel(rainImpactIndex < 0.5)
then
    float combinedHSI =
        0.6f * $s.getHeatStressIndex() +
        0.4f * $w.getHeatStressIndex();

    if (combinedHSI <= 0.7f || combinedHSI > 0.85f) return;

    EngineCategoryOutputDTO out = new EngineCategoryOutputDTO();

    out.setCategoryType(CategoryType.MICROCLIMATE);
    out.setAction("heat_mitigation");
    out.setSeverityLevel(SeverityLevel.CRITICAL);
    out.setPriorityLevel(PriorityLevel.P1);

    float confidence =
        0.7f * combinedHSI +
        0.3f * (1 - $w.getRainImpactIndex());

    out.setConfidence(Math.max(0f, Math.min(1f, confidence)));

    intermediateOutputs.add(out);
end

rule "Microclimate - Moderate Heat"
salience 75
when
    $s : DerivedSensorDataModel()
    $w : DerivedWeatherDataModel()
then
    float combinedHSI =
        0.6f * $s.getHeatStressIndex() +
        0.4f * $w.getHeatStressIndex();

    if (combinedHSI < 0.5f || combinedHSI > 0.7f) return;

    EngineCategoryOutputDTO out = new EngineCategoryOutputDTO();

    out.setCategoryType(CategoryType.MICROCLIMATE);
    out.setAction("moderate_heat_management");
    out.setSeverityLevel(SeverityLevel.HIGH);
    out.setPriorityLevel(PriorityLevel.P2);

    float confidence =
        0.6f * combinedHSI +
        0.4f * (1 - $w.getRainImpactIndex());

    out.setConfidence(Math.max(0f, Math.min(1f, confidence)));

    intermediateOutputs.add(out);
end

rule "Microclimate - Rain Cooling"
salience 60
when
    $s : DerivedSensorDataModel()
    $w : DerivedWeatherDataModel(rainImpactIndex >= 0.6)
then
    float combinedHSI =
        0.6f * $s.getHeatStressIndex() +
        0.4f * $w.getHeatStressIndex();

    if (combinedHSI <= 0.6f) return;

    EngineCategoryOutputDTO out = new EngineCategoryOutputDTO();

    out.setCategoryType(CategoryType.MICROCLIMATE);
    out.setAction("rain_cooling");
    out.setSeverityLevel(SeverityLevel.MODERATE);
    out.setPriorityLevel(PriorityLevel.P3);

    float confidence =
        0.5f * combinedHSI +
        0.5f * $w.getRainImpactIndex();

    out.setConfidence(Math.max(0f, Math.min(1f, confidence)));

    intermediateOutputs.add(out);
end

rule "Microclimate - Optimal"
salience 50
when
    $s : DerivedSensorDataModel()
    $w : DerivedWeatherDataModel()
then
    float combinedHSI =
        0.6f * $s.getHeatStressIndex() +
        0.4f * $w.getHeatStressIndex();

    if (combinedHSI >= 0.4f) return;

    EngineCategoryOutputDTO out = new EngineCategoryOutputDTO();

    out.setCategoryType(CategoryType.MICROCLIMATE);
    out.setAction("optimal_conditions");
    out.setSeverityLevel(SeverityLevel.LOW);
    out.setPriorityLevel(PriorityLevel.P4);

    float confidence =
        1f - combinedHSI;

    out.setConfidence(Math.max(0f, Math.min(1f, confidence)));

    intermediateOutputs.add(out);
end
