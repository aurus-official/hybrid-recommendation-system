package rules

rule "Crop - Delay Operations"
salience 90
when
    $m : SensorModel(psi > 0.7)
then
    RuleOutput out = new RuleOutput();
    out.setCategory("crop");
    out.setAction("delay_operations");
    out.setSeverity("CRITICAL");
    out.setPriority(1);

    float confidence = $m.getPsi();

    out.setConfidence(Math.min(1f, confidence));
    insert(out);
end

rule "Crop - Rain Adjust"
salience 80
when
    $m : SensorModel(rii >= 0.7)
then
    RuleOutput out = new RuleOutput();
    out.setCategory("crop");
    out.setAction("rain_adjust_operation");
    out.setSeverity("HIGH");
    out.setPriority(2);

    float confidence = $m.getRii();

    out.setConfidence(Math.min(1f, confidence));
    insert(out);
end

rule "Crop - Moderate Stress"
salience 70
when
    $m : SensorModel(psi >= 0.5 && psi <= 0.7)
then
    RuleOutput out = new RuleOutput();
    out.setCategory("crop");
    out.setAction("cautious_operation");
    out.setSeverity("MODERATE");
    out.setPriority(3);

    float confidence =
        1f - Math.abs($m.getPsi() - 0.6f) * 2;

    out.setConfidence(Math.min(1f, confidence));
    insert(out);
end

rule "Crop - Optimal"
salience 60
when
    $m : SensorModel(psi < 0.4, rii < 0.6)
then
    RuleOutput out = new RuleOutput();
    out.setCategory("crop");
    out.setAction("normal_operation");
    out.setSeverity("LOW");
    out.setPriority(4);

    float confidence =
        0.7f * (1 - $m.getPsi()) +
        0.3f * (1 - $m.getRii());

    out.setConfidence(Math.min(1f, confidence));
    insert(out);
end

rule "Crop - Combined Stress (NEW)"
salience 95
when
    $m : SensorModel(psi > 0.7, hsi > 0.7)
then
    RuleOutput out = new RuleOutput();
    out.setCategory("crop");
    out.setAction("suspend_operations");
    out.setSeverity("CRITICAL");
    out.setPriority(1);

    float confidence =
        0.5f * $m.getPsi() +
        0.5f * $m.getHsi();

    out.setConfidence(Math.min(1f, confidence));
    insert(out);
end
