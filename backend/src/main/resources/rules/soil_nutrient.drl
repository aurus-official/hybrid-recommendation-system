package rules

import com.aurus.server.engine.EngineCategoryOutputDTO;
import com.aurus.server.batch.derive.weather.DerivedWeatherDataModel;
import com.aurus.server.batch.derive.sensor.DerivedSensorDataModel;
import com.aurus.server.shared.PriorityLevel;
import com.aurus.server.shared.SeverityLevel;
import com.aurus.server.shared.CategoryType;

global java.util.List intermediateOutputs;

rule "Soil - Nutrient Leaching Protection"
salience 95
when
    $s : DerivedSensorDataModel(soilFertilityIndex < 0.5)
    $w : DerivedWeatherDataModel(rainImpactIndex > 0.8)
then
    EngineCategoryOutputDTO out = new EngineCategoryOutputDTO();

    out.setCategoryType(CategoryType.SOIL);
    out.setAction("avoid_fertilization");
    out.setSeverityLevel(SeverityLevel.CRITICAL);
    out.setPriorityLevel(PriorityLevel.P1);
    
    float confidence =
        0.4f * (1 - $s.getSoilFertilityIndex()) +
        0.6f * $w.getRainImpactIndex();

    out.setConfidence(Math.max(0f, Math.min(1f, confidence)));

    intermediateOutputs.add(out);
end

rule "Soil - Delay Fertilization"
salience 90
when
    $s : DerivedSensorDataModel(soilFertilityIndex < 0.4)
    $w : DerivedWeatherDataModel(rainImpactIndex >= 0.6 && rainImpactIndex <= 0.8)
then
    EngineCategoryOutputDTO out = new EngineCategoryOutputDTO();

    out.setCategoryType(CategoryType.SOIL);
    out.setAction("delay_fertilization");
    out.setSeverityLevel(SeverityLevel.CRITICAL);
    out.setPriorityLevel(PriorityLevel.P1);

    float confidence =
        0.5f * (1 - $s.getSoilFertilityIndex()) +
        0.5f * $w.getRainImpactIndex();

    out.setConfidence(Math.max(0f, Math.min(1f, confidence)));

    intermediateOutputs.add(out);
end

rule "Soil - Apply Fertilizer"
salience 85
when
    $s : DerivedSensorDataModel(soilFertilityIndex < 0.4)
    $w : DerivedWeatherDataModel(rainImpactIndex < 0.5)
then
    EngineCategoryOutputDTO out = new EngineCategoryOutputDTO();

    out.setCategoryType(CategoryType.SOIL);
    out.setAction("apply_fertilizer");
    out.setSeverityLevel(SeverityLevel.HIGH);
    out.setPriorityLevel(PriorityLevel.P2);

    float confidence =
        0.6f * (1 - $s.getSoilFertilityIndex()) +
        0.4f * (1 - $w.getRainImpactIndex());

    out.setConfidence(Math.max(0f, Math.min(1f, confidence)));

    intermediateOutputs.add(out);
end

rule "Soil - Maintain Soil"
salience 60
when
    $s : DerivedSensorDataModel(
        soilFertilityIndex >= 0.4 &&
        soilFertilityIndex <= 0.7
    )
then
    EngineCategoryOutputDTO out = new EngineCategoryOutputDTO();

    out.setCategoryType(CategoryType.SOIL);
    out.setAction("maintain_soil");
    out.setSeverityLevel(SeverityLevel.MODERATE);
    out.setPriorityLevel(PriorityLevel.P3);

    float confidence =
        1f - Math.abs($s.getSoilFertilityIndex() - 0.55f) * 2;

    out.setConfidence(Math.max(0f, Math.min(1f, confidence)));

    intermediateOutputs.add(out);
end

rule "Soil - Optimize Uptake"
salience 65
when
    $s : DerivedSensorDataModel(soilFertilityIndex > 0.7)
    $w : DerivedWeatherDataModel(waterBalanceIndex >= 0.5)
then
    EngineCategoryOutputDTO out = new EngineCategoryOutputDTO();

    out.setCategoryType(CategoryType.SOIL);
    out.setAction("optimize_nutrients");
    out.setSeverityLevel(SeverityLevel.LOW);
    out.setPriorityLevel(PriorityLevel.P4);

    float confidence =
        0.6f * $s.getSoilFertilityIndex() +
        0.4f * $w.getWaterBalanceIndex();

    out.setConfidence(Math.max(0f, Math.min(1f, confidence)));

    intermediateOutputs.add(out);
end
