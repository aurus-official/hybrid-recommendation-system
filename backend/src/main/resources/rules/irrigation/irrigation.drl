package rules.irrigation

import com.aurus.server.engine.EngineCategoryOutputDTO;
import com.aurus.server.batch.derive.weather.DerivedWeatherDataModel;
import com.aurus.server.batch.derive.sensor.DerivedSensorDataModel;
import com.aurus.server.shared.PriorityLevel;
import com.aurus.server.shared.SeverityLevel;
import com.aurus.server.shared.CategoryType;


global java.util.List intermediateOutputs;


rule "Irrigation - Suspend Due to Heavy Rain"
salience 100
when
    $w : DerivedWeatherDataModel(rainImpactIndex >= 0.75)
then
    EngineCategoryOutputDTO out = new EngineCategoryOutputDTO();
    out.setCategoryType(CategoryType.IRRIGATION);
    out.setAction("suspend_irrigation_due_to_rain");
    out.setSeverityLevel(SeverityLevel.CRITICAL);
    out.setPriorityLevel(PriorityLevel.P0);

    out.setConfidence($w.getRainImpactIndex());
    intermediateOutputs.add(out);
end


rule "Irrigation - Emergency Deep Irrigation"
salience 95
when
    $w : DerivedWeatherDataModel(waterBalanceIndex <= 0.3)
    $s : DerivedSensorDataModel(evaporationDryingRisk >= 0.7)
then
    EngineCategoryOutputDTO out = new EngineCategoryOutputDTO();
    out.setCategoryType(CategoryType.IRRIGATION);
    out.setAction("apply_deep_irrigation_immediately");
    out.setSeverityLevel(SeverityLevel.CRITICAL);
    out.setPriorityLevel(PriorityLevel.P0);

    float confidence =
        0.5f * (1 - $w.getWaterBalanceIndex()) +
        0.3f * $s.getEvaporationDryingRisk() +
        0.2f * (1 - $w.getRainImpactIndex());

    out.setConfidence(Math.min(1f, confidence));
    intermediateOutputs.add(out);
end


rule "Irrigation - Increase Frequency"
salience 90
when
    $w : DerivedWeatherDataModel(waterBalanceIndex < 0.5, rainImpactIndex < 0.6)
    $s : DerivedSensorDataModel(evaporationDryingRisk >= 0.6 && evaporationDryingRisk < 0.75)
then
    EngineCategoryOutputDTO out = new EngineCategoryOutputDTO();
    out.setCategoryType(CategoryType.IRRIGATION);
    out.setAction("increase_irrigation_frequency");
    out.setSeverityLevel(SeverityLevel.HIGH);
    out.setPriorityLevel(PriorityLevel.P1);

    float confidence =
        0.5f * (1 - $w.getWaterBalanceIndex()) +
        0.5f * $s.getEvaporationDryingRisk();

    out.setConfidence(Math.min(1f, confidence));
    intermediateOutputs.add(out);
end


rule "Irrigation - Split Irrigation Scheduling"
salience 85
when
    $w : DerivedWeatherDataModel(waterBalanceIndex >= 0.3 && waterBalanceIndex < 0.5, rainImpactIndex < 0.6)
    $s : DerivedSensorDataModel(evaporationDryingRisk >= 0.5 && evaporationDryingRisk < 0.6)
then
    EngineCategoryOutputDTO out = new EngineCategoryOutputDTO();
    out.setCategoryType(CategoryType.IRRIGATION);
    out.setAction("apply_split_irrigation_schedule");
    out.setSeverityLevel(SeverityLevel.HIGH);
    out.setPriorityLevel(PriorityLevel.P1);

    float confidence =
        0.5f * (1 - $w.getWaterBalanceIndex()) +
        0.5f * $s.getEvaporationDryingRisk();

    out.setConfidence(Math.min(1f, confidence));
    intermediateOutputs.add(out);
end


rule "Irrigation - Maintain Balanced Irrigation"
salience 80
when
    $w : DerivedWeatherDataModel(waterBalanceIndex >= 0.5 && waterBalanceIndex <= 0.7, rainImpactIndex < 0.6)
    $s : DerivedSensorDataModel(evaporationDryingRisk < 0.5)
then
    EngineCategoryOutputDTO out = new EngineCategoryOutputDTO();
    out.setCategoryType(CategoryType.IRRIGATION);
    out.setAction("maintain_current_irrigation_schedule");
    out.setSeverityLevel(SeverityLevel.MODERATE);
    out.setPriorityLevel(PriorityLevel.P2);

    float confidence =
        1f - Math.abs($w.getWaterBalanceIndex() - 0.6f);

    out.setConfidence(Math.min(1f, Math.max(0f, confidence)));
    intermediateOutputs.add(out);
end


rule "Irrigation - Reduce Irrigation Volume"
salience 70
when
    $w : DerivedWeatherDataModel(waterBalanceIndex > 0.7 && rainImpactIndex < 0.75)
    $s : DerivedSensorDataModel(evaporationDryingRisk < 0.5)
then
    EngineCategoryOutputDTO out = new EngineCategoryOutputDTO();
    out.setCategoryType(CategoryType.IRRIGATION);
    out.setAction("reduce_irrigation_volume");
    out.setSeverityLevel(SeverityLevel.LOW);
    out.setPriorityLevel(PriorityLevel.P3);

    float confidence =
        0.6f * $w.getWaterBalanceIndex() +
        0.4f * (1 - $s.getEvaporationDryingRisk());

    out.setConfidence(Math.min(1f, confidence));
    intermediateOutputs.add(out);
end


rule "Irrigation - Default Safe Irrigation"
salience 10
when
    $w : DerivedWeatherDataModel()
    $s : DerivedSensorDataModel()
then
    EngineCategoryOutputDTO out = new EngineCategoryOutputDTO();
    out.setCategoryType(CategoryType.IRRIGATION);
    out.setAction("apply_light_irrigation_monitor_conditions");
    out.setSeverityLevel(SeverityLevel.LOW);
    out.setPriorityLevel(PriorityLevel.P3);

    out.setConfidence(0.5f);
    intermediateOutputs.add(out);
end
